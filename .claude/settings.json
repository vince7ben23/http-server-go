{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/build.sh",
            "timeout": 30,
            "statusMessage": "Building..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/test.sh",
            "timeout": 60,
            "statusMessage": "Testing server..."
          }
        ]
      }
    ]
  }
}
